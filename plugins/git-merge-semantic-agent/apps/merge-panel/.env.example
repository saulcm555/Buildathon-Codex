VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
VITE_MCP_URL=http://localhost:3000/mcp
VITE_LOCAL_MODE=true
# Local mode only: absolute repository path and the relative path of a file
# that is currently in a Git merge conflict.
VITE_REPOSITORY_PATH=C:/path/to/your/repository
VITE_FILE_PATH=src/path/to/conflicted-file.ts
